# =============================================================
# AdminPortal — Environment Variable Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git (already in .gitignore).
# =============================================================

# --- Gmail SMTP Configuration ---
# Use an "App Password" if 2-Step Verification is enabled on your Google Account
# Go to: Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# --- JWT Secret ---
# Must match the JWT_SECRET used by your backend API (ap-is-seven).
# Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Then add the SAME value to Vercel → Settings → Environment Variables.
JWT_SECRET=your-64-byte-hex-secret-here
